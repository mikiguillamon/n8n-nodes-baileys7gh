{
	"name": "n8n-nodes-baileys-instance",
	"version": "0.1.4",
	"description": "n8n community node for the wa-instance API built on top of Baileys 7.",
	"license": "MIT",
	"homepage": "https://github.com/mikiguillamon/n8n-nodes-baileys7gh",
	"bugs": {
		"url": "https://github.com/mikiguillamon/n8n-nodes-baileys7gh/issues"
	},
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"whatsapp",
		"baileys",
		"community-node"
	],
	"author": {
		"name": "Miki Guillamon"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/mikiguillamon/n8n-nodes-baileys7gh.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"prepublishOnly": "npm run lint && npm run build",
		"publish:manual": "npm publish --access public",
		"smoke": "npm run lint && npm run build",
		"typecheck": "tsc --noEmit",
		"release": "n8n-node release"
	},
	"files": [
		"dist"
	],
	"engines": {
		"node": ">=22.14.0"
	},
	"publishConfig": {
		"access": "public"
	},
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/BaileysInstanceApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/BaileysInstance/BaileysInstance.node.js",
			"dist/nodes/BaileysTrigger/BaileysTrigger.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.29.0",
		"prettier": "3.8.3",
		"release-it": "20.2.0",
		"typescript": "5.9.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	},
	"packageManager": "npm@11.3.0"
}
